# hulk 배포 위치(/home/hulk/working/reporter.crefle.com)에 .env 로 복사해 사용.
# .env 는 이미지에 굽히지 않고 docker compose 가 런타임에 주입한다.

# 읽기(열람) Basic Auth
REPORTS_USER=crefle
REPORTS_PASS=crefle

# 쓰기(업로드) 전용 자격증명 — 반드시 강한 값으로 설정. 미설정 시 compose 기동 거부.
REPORTS_UPLOAD_USER=crefle
REPORTS_UPLOAD_PASS=__SET_A_STRONG_UPLOAD_PASSWORD__
