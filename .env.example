# hulk 배포 위치(/home/hulk/working/reporter.crefle.com)에 .env 로 복사해 사용.
# .env 는 이미지에 굽히지 않고 docker compose 가 런타임에 주입한다.

# 읽기(열람) Basic Auth
REPORTS_USER=crefle
REPORTS_PASS=crefle

# 쓰기(업로드) 전용 자격증명 — 반드시 강한 값으로 설정. 미설정 시 compose 기동 거부.
REPORTS_UPLOAD_USER=crefle
REPORTS_UPLOAD_PASS=__SET_A_STRONG_UPLOAD_PASSWORD__

# 세션(JWT) 서명 키 — 반드시 강한 무작위 값(예: openssl rand -hex 32). 미설정 시 임시 키(재시작마다 로그아웃).
REPORTS_SECRET_KEY=__SET_A_RANDOM_HEX_SECRET__
# 토큰 수명(초). 기본 1209600(14일).
REPORTS_TOKEN_TTL=1209600
# HTTPS(TLS) 뒤에서 1, 평문 HTTP(:28080)면 0.
REPORTS_COOKIE_SECURE=0

# 자료별 외부 공개(public share) 링크의 베이스 URL.
# 미설정 시 요청 Origin 을 사용한다. 리버스프록시 뒤 외부 접속 도메인이 다르면 설정(끝 슬래시 제외).
# 예) REPORTS_PUBLIC_BASE_URL=https://reporter.crefle.com
#REPORTS_PUBLIC_BASE_URL=
